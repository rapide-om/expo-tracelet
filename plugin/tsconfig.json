{
    "compilerOptions": {
        "outDir": "build",
        "rootDir": "src",
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "ES2019",
        "esModuleInterop": true,
        "strict": true,
        "declaration": true,
        "skipLibCheck": true,
        "lib": ["ES2019"]
    },
    "include": ["src"],
    "exclude": ["build", "node_modules"]
}
